# Copy to .env and fill in your values.

# OpenAI-compatible endpoint (internal BNP or any compatible LLM gateway)
LLM_BASE_URL=https://your-internal-endpoint/v1
LLM_API_KEY=your-api-key-here

# Default model used when a role-specific override is not set
LLM_MODEL=qwen3

# Per-role overrides (optional)
# Available models on the internal endpoint:
#   qwen3          — general purpose
#   codestral      — code specialized
#   gpt-oss-120b   — large model, best for synthesis
#   mistral-medium — balanced
#   gemma3-27b     — good reasoning
LLM_MODEL_INSPECTOR=qwen3
LLM_MODEL_DOC=qwen3
LLM_MODEL_DATA=qwen3
LLM_MODEL_RULES=codestral
LLM_MODEL_CARTOGRAPHER=gpt-oss-120b

# Corporate proxy (optional)
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port
# SSL_VERIFY=false

# Paths
INPUT_DIR=./input/raw
OUTPUT_DIR=./output

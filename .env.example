# LLM - shared endpoint (OpenAI-compatible)
LLM_BASE_URL=https://your-internal-endpoint/v1
LLM_API_KEY=your-api-key-here

# Multi-model pipeline
# Available models on the internal endpoint:
#   qwen3          — general purpose, internal BNP
#   codestral      — code specialized (best for Java/SQL analysis)
#   gpt-oss-120b   — large model, best for synthesis and judgment
#   mistral-medium — balanced performance
#   gemma3-27b     — Google model, good reasoning

LLM_MODEL_ANALYST1=qwen3          # Analyst 1
LLM_MODEL_ANALYST2=codestral      # Analyst 2 — code specialized
LLM_MODEL_JUDGE=gpt-oss-120b      # Judge — synthesizes best result

# Code-generation pipeline (Spring Batch 5 / Java 17)
LLM_MODEL_DEVELOPER=              # Developer — drafts Spring Batch code
LLM_MODEL_REVIEWER=               # Reviewer — rewrites and finalises

# Corporate proxy (optional)
# HTTP_PROXY=http://proxy-host:port
# HTTPS_PROXY=http://proxy-host:port
# SSL_VERIFY=false

# Oracle Database
DB_HOST=your-oracle-host
DB_PORT=1521
DB_SERVICE=your-service-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Paths
LEGACY_CODE_DIR=./legacy_code
OUTPUT_DIR=./output
